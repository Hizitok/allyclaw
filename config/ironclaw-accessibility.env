# AllyClaw Recommended Settings for IronClaw
# Copy this to ~/.ironclaw/.env and adjust as needed

# === LLM Provider ===
# Options: nearai, anthropic, openai, ollama
LLM_BACKEND=nearai

# === TTS (Text-to-Speech) ===
# TTS is in development - these will be used once implemented
# TTS_PROVIDER=edge
# TTS_VOICE=en-US-AriaNeural
# TTS_AUTO=true
# TTS_RATE=+0%
# TTS_PITCH=+0Hz
# TTS_VOLUME=+0%

# === Voice (Talk Mode) ===
# Requires ElevenLabs API key for voice conversations
# VOICE_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=your_key_here
# VOICE_ID=your_voice_id

# === Accessibility ===
# SCREEN_READER_MODE=true
# KEYBOARD_ONLY_MODE=true
# HIGH_CONTRAST_MODE=true
# ANNOUNCE_ERRORS=true
# ANNOUNCE_ACTIONS=true

# === Network ===
# Bind to localhost only for security
# HOST=127.0.0.1
# PORT=3456

# === Logging ===
LOG_LEVEL=info
